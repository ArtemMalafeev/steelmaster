---
import { Image } from "astro:assets";

import main from "../images/main.jpg";

import SuccessIcon from "../components/icons/Success.astro";
---

<section id="main" class="section main" aria-labelledby="hero-title">
  <div class="container">
    <div class="main__container">
      <div class="main__description">
        <h1 class="main__title" id="hero-title">
          Производство и монтаж <span>всех видов ворот и заборов</span> в Ставропольском крае под ключ 
        </h1>
        <p class="main__info">
          Работаем на любом типе грунта. От бюджетных вариантов до премиум сегмента
        </p>
        <ul class="main__list">
          <li class="main__item">
            <div class="main__icon" aria-hidden="true"><SuccessIcon /></div>
            <span>Предоставляем гарантию</span>
          </li>
          <li class="main__item">
            <div class="main__icon" aria-hidden="true"><SuccessIcon /></div>
            <span>Собственное производство</span>
          </li>
          <li class="main__item">
            <div class="main__icon" aria-hidden="true"><SuccessIcon /></div>
            <span>Быстрый монтаж</span>
          </li>
        </ul>

        <div class="main__actions">
          <a class="main__calculateBtn" data-ya-click="calculate_hero" aria-label="Перейти к калькулятору стоимости" href="#calculate"
            >Рассчитать стоимость</a
          >
          <a class="main__worksBtn"   data-ya-click="works_hero"
+    aria-label="Посмотреть наши работы" href="#works">Наши работы</a>
        </div>

        <div class="main__stat" role="group" aria-label="Статистика компании">
          <div class="main__statItem">
            <p class="main__statTitle">500+</p>
            <p class="main__statInfo">Выполненных проектов</p>
          </div>
          <div class="main__statItem">
            <p class="main__statTitle">12</p>
            <p class="main__statInfo">Лет на рынке</p>
          </div>
          <div class="main__statItem">
            <p class="main__statTitle">98%</p>
            <p class="main__statInfo">Довольных клиентов</p>
          </div>
        </div>
      </div>

      <div
        class="main__img"
      >
        <Image 
          src={main} 
          alt="Монтаж забора из профнастила под ключ в [Город]"
          loading="eager"       
          fetchpriority="high"  
        />
        <div class="main__imgInfo">
          <span class="main__imgInfoText">От</span>
          <span class="main__imgInfoPrice">15 000 ₽</span>
          <span class="main__imgInfoText">за погонный метр</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .main {
    background: var(--color-bg-1);
    padding: 4rem 0;

    &__container {
      display: flex;
      align-items: stretch;
      gap: 90px;
    }

    &__description {
      flex: 1;
      display: flex;
      flex-direction: column;
      row-gap: 26px;
      justify-content: center;
    }

    &__list {
      display: flex;
      flex-direction: column;
      row-gap: 12px;
    }

    &__item {
      display: flex;
      column-gap: 8px;
      align-items: center;

      span {
        font-size: 16px;
        color: var(--color-gray-700);
      }
    }

    &__icon {
      width: 26px;
      height: 26px;
      color: var(--color-primary);
    }

    &__title {
      max-width: 450px;
      span {
        color: var(--color-primary);
      }
    }

    &__info {
      max-width: 350px;
      font-size: 22px;
      color: var(--color-gray-700);
    }

    &__actions {
      display: flex;
      flex-direction: column;
      gap: 16px;
      align-items: center;

      @media screen and (min-width: 500px) {
        flex-direction: initial;
      }
    }

    &__calculateBtn {
      padding: 20px 30px;
      font-size: 18px;
      font-weight: 500;
      border-radius: 10px;
      color: var(--color-white);
      background-color: var(--color-primary);
      border: 2px solid transparent;
      transition: background-color 0.2s;
      cursor: pointer;
      text-decoration: none;

      &:hover {
        background-color: var(--color-primary-hover);
      }
    }

    &__worksBtn {
      padding: 20px 30px;
      font-size: 18px;
      font-weight: 500;
      border-radius: 10px;
      color: var(--color-secondary);
      background-color: transparent;
      border: 2px solid var(--color-secondary);
      transition: background-color 0.2s;
      cursor: pointer;
      text-decoration: none;

      &:hover {
        background-color: var(--color-btn-outline-hover);
      }
    }

    &__calculateBtn,
    &__worksBtn {
      width: 100%;
      max-width: 250px;
      text-align: center;

      @media screen and (min-width: 500px) {
        width: max-content;
      }
    }


    &__stat {
      display: flex;
      gap: 24px;
      margin-top: 20px;
    }

    &__statItem {
      display: flex;
      flex-direction: column;
      row-gap: 6px;
    }

    &__statTitle {
      font-size: 34px;
      font-weight: 700;
      color: var(--color-primary);
    }

    &__statInfo {
      font-size: 16px;
      color: var(--color-secondary);
    }

    &__img {
      flex: 1.4;
      align-self: center;
      position: relative;
      max-width: 700px;
      max-height: 600px;
      overflow: hidden;
      border-radius: 20px;
      box-shadow: 
  0 10px 20px rgba(0, 0, 0, 0.15),
  0 25px 50px rgba(0, 0, 0, 0.25);

        &::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0, 0, 0, 0.35) 0%, transparent 60%);
        border-radius: 16px;
        pointer-events: none; 
        z-index: 1;
      }

      img {
        width: 100%;
        height: auto;
        object-fit: cover;
        display: block;
        border-radius: 16px;

      }
    }

    @media (max-width: 992px) {
      &__img {
        flex: none;
        max-height: 400px;
        width: 100%;
      }
    }

    &__imgInfo {
      position: absolute;
      bottom: 15px;
      right: 15px;
      display: flex;
      flex-direction: column;
      row-gap: 4px;
      padding: 10px 24px;
      border-radius: 12px;
      width: max-content;
      background-color: var(--color-white);
      box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.15);
    }

    &__imgInfoPrice {
      font-size: 26px;
      font-weight: 700;
      color: var(--color-primary);
    }

    &__imgInfoText {
      font-size: 14px;
      color: var(--color-secondary);
    }

    @media (max-width: 992px) {
      &__container {
        flex-direction: column;
        gap: 30px;
      }
    }
  }
</style>
