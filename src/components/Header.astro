---
import { Image } from "astro:assets";
import logo from "../images/logo.jpg";
import WatchIcon from "../components/icons/Watch.astro";
import AddressIcon from "../components/icons/Address.astro";
import PhoneIcon from "../components/icons/Phone.astro";
---

<header class="header">
  <div class="header__container">
    <div class="header__top">
      <div class="container">
        <div class="header__info">
          <div class="header__infoItem">
            <div class="header__infoIcon" aria-hidden="true"><WatchIcon /></div>
            <span>Пн-Пт: 9:00-18:00</span>
          </div>
          <div class="header__infoItem">
            <div class="header__infoIcon" aria-hidden="true">
              <AddressIcon />
            </div>
            <span>Шпаковский р-н, х. Вязники, 92</span>
          </div>
        </div>
        <div class="header__socials"></div>
      </div>
    </div>
    <div class="header__bottom">
      <div class="container">
        <div class="header__bottomContainer">
          <div class="header__company">
            <Image src={logo} alt="Логотип СТАЛЬМАСТЕР" class="header__logo" />
            <div class="header__companyInfo">
              <p class="header__companyName">СТАЛЬМАСТЕР</p>
              <p class="header__companyDescription">
                Изготовление ворот в Ставропольском крае
              </p>
            </div>
          </div>

          <nav class="header__nav nav" id="mainNav">
            <a href="#choose" class="nav__link">Преимущества</a>
            <a href="#services" class="nav__link">Услуги</a>
            <a href="#works" class="nav__link">Примеры работ</a>
            <a href="#reviews" class="nav__link">Отзывы</a>
            <a href="#calculate" class="nav__link">Калькулятор</a>
          </nav>

          <div class="header__contacts">
            <div class="header__phone">
              <div class="header__phoneIcon" aria-hidden="true">
                <PhoneIcon />
              </div>
              <span class="header__phoneNumber">+7 (918) 768 30 88</span>
            </div>
            <button class="header__callbackBtn" data-modal-trigger="call" aria-label="Заказать звонок" type="button"
              >Заказать звонок</button
            >
          </div>

          <button
            class="header__burger"
            id="burgerBtn"
            aria-label="Открыть меню"
            aria-expanded="false"
            aria-controls="mainNav"
          >
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const burger = document.getElementById("burgerBtn");
    const nav = document.getElementById("mainNav");
    burger?.addEventListener("click", () => {
      const isOpen = nav?.classList.toggle("active");
      burger.classList.toggle("active");
      burger.setAttribute("aria-expanded", isOpen);
    });
    nav?.querySelectorAll(".nav__link, .nav__phone").forEach((link) => {
      link.addEventListener("click", () => {
        nav.classList.remove("active");
        burger.classList.remove("active");
        burger.setAttribute("aria-expanded", "false");
      });
    });
  </script>

  <style lang="scss">
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 4px 12px -2px rgba(0, 0, 0, 0.08);
      background: var(--color-white);

      &__top {
        padding: 6px 0;
        font-size: 12px;
        background: var(--color-bg-secondary);
      }

      &__info {
        display: flex;
        gap: 32px;
        color: var(--color-white);
      }

      &__infoItem {
        display: flex;
        align-items: center;
        gap: 6px;
      }

      &__infoIcon {
        width: 18px;
        height: 18px;
        color: var(--color-primary);
      }

      &__bottom {
        padding: 16px 0;
      }

      &__nav {
        margin-left: 20px;
      }

      &__bottomContainer {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      &__company {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      &__logo {
        width: 50px;
        height: 50px;
        object-fit: contain;
      }

      &__companyInfo {
        display: flex;
        flex-direction: column;
        row-gap: 2px;
      }
      &__companyName {
        font-size: 18px;
        font-weight: 700;
        line-height: 1.2;
      }
      &__companyDescription {
        font-size: 11px;
        color: var(--color-gray-700);
      }

      &__contacts {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-left: auto;
      }
      &__phone {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
      }
      &__phoneIcon {
        width: 20px;
        height: 20px;
        color: var(--color-primary);
      }

      &__callbackBtn {
        padding: 10px 20px;
        font-weight: 500;
        border-radius: 10px;
        color: var(--color-white);
        background-color: var(--color-primary);
        transition: background-color 0.2s;
        border: 2px solid transparent;
        &:hover {
          background-color: var(--color-primary-hover);
        }
      }

      &__burger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 32px;
        height: 32px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        span {
          display: block;
          width: 100%;
          height: 2px;
          background: var(--color-text);
          transition: 0.3s;
          transform-origin: center;
        }
        &.active {
          span:nth-child(1) {
            transform: translateY(7px) rotate(45deg);
          }
          span:nth-child(2) {
            opacity: 0;
          }
          span:nth-child(3) {
            transform: translateY(-7px) rotate(-45deg);
          }
        }
      }
    }

    .nav {
      display: flex;
      gap: 24px;
    }
    .nav__link {
      font-weight: 500;
      color: var(--color-gray-700);
      text-decoration: none;
      transition: color 0.25s;
      &:hover {
        color: var(--color-primary);
      }
    }
    .nav__phone {
      display: none;
      align-items: center;
      gap: 8px;
      color: var(--color-text);
      font-weight: 600;
      text-decoration: none;
    }
    .nav__phoneIcon {
      width: 20px;
      height: 20px;
      color: var(--color-primary);
    }

    @media (max-width: 1250px) {
      .header {
        &__burger {
          display: flex;
          margin-left: 24px;

          span {
            background: var(--color-primary);
          }
          &.active {
            span {
              background: var(--color-primary);
            }
          }
        }
        &__bottomContainer {
          position: relative;
        }
        &__nav {
          position: absolute;
          top: calc(100% + 16px);
          left: 0;
          right: 0;
          background: var(--color-white);
          padding: 16px;
          flex-direction: column;
          gap: 0;
          box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
          border-radius: 12px;
          transform: translateY(-10px);
          opacity: 0;
          pointer-events: none;
          transition: 0.25s ease;
          &.active {
            transform: translateY(0);
            opacity: 1;
            pointer-events: auto;
          }
          .nav__link {
            padding: 14px 0;
            border-bottom: 1px solid var(--color-gray-100);
            width: 100%;
          }
          .nav__phone {
            display: flex;
            padding: 14px 0;
          }
        }
        &__phone {
          display: none;
        }
        &__callbackBtn {
          padding: 10px 16px;
          font-size: 14px;
        }
      }
    }

    @media (max-width: 576px) {
      .header {
        &__companyInfo {
          display: none;
        }
        &__logo {
          width: 44px;
          height: 44px;
        }

        &__top {
          padding: 8px 0;
        }
        &__bottom {
          padding: 12px 0;
        }
      }
    }
  </style>
</header>
