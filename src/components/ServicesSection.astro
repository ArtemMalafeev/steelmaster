---
import { Image } from "astro:assets";

import WatchIcon from "../components/icons/Watch.astro";
import main from "../images/main.jpg";

const servicesData = [
  {
    title: "Ворота любых типов из металла",
    description: "Откатные, распашные, подъёмные и промышленные ворота.",
    price: "от 50 000 ₽",
    image: main,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    features: ["Любая ширина и высота", "Усиленный каркас", "Монтаж за 1–2 дня"]
  },
  {
    title: "Перила",
    description: "Лестничные перила, ограждения для балконов и террас.",
    price: "от 50 000 ₽",
    image: main,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h16M4 14h16M4 18h16M8 6v12M16 6v12M6 4h12v2H6z"/></svg>`,
    features: ["Нержавейка или чёрный металл", "Антикоррозийная обработка"]
  },
  {
    title: "Ангары",
    description: "Быстровозводимые ангары и навесы для техники, склада или производства.",
    price: "от 50 000 ₽",
    image: main,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V7l8-4 8 4v14M8 21v-9a2 2 0 012-2h4a2 2 0 012 2v9"/></svg>`,
    features: ["От 20 м² до 1000 м²", "Усиленный каркас под снег/ветер", "Срок службы от 25 лет"]
  },
  {
    title: "Металлические конструкции",
    description: "Каркасы зданий, фермы, колонны, закладные детали и нестандартные узлы.",
    price: "от 50 000 ₽",
    image: main,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3zM9 3v18M15 3v18M3 9h18M3 15h18"/></svg>`,
    features: ["Точный расчёт нагрузок", "Сварка и резка ЧПУ"]
  },
  {
    title: "Изделия по вашим чертежам",
    description: "Реализуем проекты любой сложности: от кованых элементов до промышленных узлов.",
    price: "от 50 000 ₽",
    image: main,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    features: ["Работа по ТЗ заказчика", "Гибкие допуски и точность"]
  },
  {
    title: "Автоматизация проезда",
    description: "Установка приводов, шлагбаумов и систем контроля доступа.",
    price: "от 50 000 ₽",
    image: main,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/></svg>`,
    features: ["Бренды CAME, Nice, DoorHan", "Пульты и фотоэлементы"]
  }
];
---

<section
  id="services"
  class="section services"
  aria-labelledby="services-title"
>
  <div class="container">
    <div class="services__container">
      <div class="services__top">
        <h2 id="services-title" class="services__title">Наши услуги</h2>
        <p class="services__subtitle">
          Полный цикл работ: от проектирования до монтажа и обслуживания
        </p>
      </div>
      <ul class="services__list">
        {
          servicesData.map((service) => (
            <li class="services__item">
              <div class="services__top">
                <Image
                  class="services__image"
                  src={service.image}
                  alt={`Пример услуги: ${service.title}`}
                />
                <div class="services__topInfo">{service.price}</div>
              </div>
              <div class="services__cardBottom">
                <div class="services__cardHero">
                  <div class="services__icon" aria-hidden="true" set:html={service.icon} />
                  <h3 class="services__cardTitle">{service.title}</h3>
                </div>
                <p class="services__cardDescription">{service.description}</p>
                <ul class="services__cardList">
                  {service.features.map((feature) => (
                    <li class="services__cardItem">{feature}</li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
  .services {
    background: var(--color-bg-2);

    &__container {
      text-align: center;
    }

    &__top {
      position: relative;
      display: flex;
      flex-direction: column;
      row-gap: 18px;
    }

    &__topInfo {
      position: absolute;
      top: 12px;
      right: 12px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 500;
      border-radius: 12px;
      color: var(--color-white);
      background-color: var(--color-primary);
    }

    &__icon {
      width: 24px;
      height: 24px;
      padding: 10px;
      color: var(--color-primary);
      background: var(--color-bg-3);
      border-radius: 12px;
    }

    &__subtitle {
      font-size: 22px;
      color: var(--color-secondary);
    }

    &__item {
      border-radius: 20px;
      overflow: hidden;
      text-align: left;
      background-color: var(--color-white);
      box-shadow: 0 12px 24px -6px rgba(0, 0, 0, 0.12);
    }

    &__cardHero {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    &__cardBottom {
      display: flex;
      flex-direction: column;
      row-gap: 14px;
    }

    &__cardDescription {
      font-size: 16px;
      line-height: 1.4;
      color: var(--color-secondary);
    }

    &__cardList {
      display: flex;
      flex-direction: column;
      row-gap: 10px;
      list-style-type: disc;
      padding-left: 20px;
    }

    &__cardItem {
      font-size: 14px;
      color: var(--color-secondary);

      &::marker {
        color: var(--color-primary);
        font-size: 1.1em;
      }
    }

    &__cardTitle {
      font-size: 20px;
      font-weight: 500;
    }

    &__image {
      display: block;
      width: 100%;
      height: 250px;
      object-fit: cover;
    }

    &__cardBottom {
      padding: 24px;
    }

    &__list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-top: 50px;

      @media screen and (min-width: 720px) {
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      }
    }
  }
</style>
