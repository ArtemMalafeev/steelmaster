---
import PhoneIcon from "../components/icons/Phone.astro";
import MapIcon from "../components/icons/Map.astro";
import WatchIcon from "../components/icons/Watch.astro";
import EmailIcon from "../components/icons/Email.astro";
import MaxIcon from "../components/icons/socials/Max.astro";
import TelegramIcon from "../components/icons/socials/Telegram.astro";
import WhatsAppIcon from "../components/icons/socials/WhatsApp.astro";
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__col footer__col--brand">
        <a
          href="/"
          class="footer__logo"
          aria-label="ВоротаПро — главная страница"
        >
          <span class="footer__logoText">СТАЛЬМАСТЕР</span>
        </a>
        <p class="footer__description">
          Изготовление ворот в Ставропольском крае
        </p>

        <div class="footer__socials">
          <a
            href="https://wa.me/79187683088"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__socialLink"
            aria-label="Написать в WhatsApp"
          >
            <WhatsAppIcon />
          </a>

          <a
            href="https://t.me/stalmasterpro"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__socialLink"
            aria-label="Написать в Telegram"
          >
            <TelegramIcon />
          </a>

          <a
            href="https://web.max.ru/261199918"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__socialLink"
            aria-label="Написать в Max"
          >
            <MaxIcon />
          </a>
        </div>
      </div>

      <nav
        class="footer__col footer__col--nav"
        aria-labelledby="footer-info-title"
      >
        <h4 id="footer-info-title" class="footer__colTitle">Меню</h4>
        <ul class="footer__list">
          <li class="footer__listItem">
            <a href="#main" class="footer__link">О компании</a>
          </li>
          <li class="footer__listItem">
            <a href="#choose" class="footer__link">Преимущества</a>
          </li>
          <li class="footer__listItem">
            <a href="#services" class="footer__link">Услуги</a>
          </li>
          <li class="footer__listItem">
            <a href="#works" class="footer__link">Примеры работ</a>
          </li>
          <li class="footer__listItem">
            <a href="#reviews" class="footer__link">Отзывы</a>
          </li>
          <li class="footer__listItem">
            <a href="#calculator" class="footer__link">Калькулятор</a>
          </li>
          <li class="footer__listItem">
            <a href="#contacts" class="footer__link">Контакты</a>
          </li>
        </ul>
      </nav>

      <div class="footer__col footer__col--contacts">
        <h4 class="footer__colTitle">Контакты</h4>
        <address class="footer__address" itemscope>
          <ul class="footer__contactList">
            <li class="footer__contactItem">
              <a
                href="tel:+79991234567"
                class="footer__contactLink"
                itemprop="telephone"
              >
                <div class="footer__contactIcon">
                  <PhoneIcon />
                </div>
                <span itemprop="telephone">+7 (918) 768 30 88</span>
              </a>
            </li>

            <li class="footer__contactItem">
              <a
                href="mailto:valeriya.k1995@icloud.com"
                class="footer__contactLink"
                itemprop="telephone"
              >
                <div class="footer__contactIcon">
                  <EmailIcon />
                </div>
                <span itemprop="telephone">valeriya.k1995@icloud.com</span>
              </a>
            </li>

            <li
              class="footer__contactItem"
              itemprop="address"
              itemscope
              itemtype="https://schema.org/PostalAddress"
            >
              <div class="footer__contactIcon">
                <MapIcon />
              </div>

              <a
                href="#contacts"
                class="footer__contactLink"
                itemprop="streetAddress">Шпаковский р-н, х. Вязники, 92</a
              >
            </li>
            <li class="footer__contactItem">
              <div class="footer__contactIcon">
                <WatchIcon />
              </div>

              <time datetime="2024-01-01T09:00/2024-12-31T20:00"
                >Пн-Пт: 9:00-18:00</time
              >
            </li>
          </ul>
        </address>
      </div>

      <div class="footer__col" aria-labelledby=" footer-services-title">
        <h4 id="footer-services-title" class="footer__colTitle">Информация</h4>
        <p class="footer__description">
          Перепечатка материалов сайта без письменного разрешения запрещена
        </p>
        <p class="footer__description">
          Вся информация, размещенная на сайте, носит ознакомительный характер и
          может отличаться от дейсвительности.
        </p>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">
        © <time datetime="2026">2026</time> СТАЛЬМАСТЕР. Все права защищены.
      </p>
      <nav class="footer__legal" aria-label="Юридическая информация">
        <a href="/privacy" class="footer__legalLink"
          >Политика конфиденциальности</a
        >
      </nav>
    </div>
  </div>
</footer>

<style lang="scss">
  .footer {
    background: var(--color-bg-4);
    background: var(--color-bg-4);
    color: var(--color-white);
    padding: 3rem 0 1.5rem;
    font-size: 14px;
    line-height: 1.5;

    &__grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr 1.3fr;
      gap: 2rem 1.5rem;
      margin-bottom: 2rem;
    }

    &__col {
      display: flex;
      flex-direction: column;
      gap: 1rem;

      &--brand {
        gap: 1.25rem;
      }

      &--nav {
        gap: 1rem;
      }

      &--contacts {
        gap: 1rem;
      }
    }

    &__socials {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    &__socialLink {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      color: var(--color-white);
      transition: color 0.2s ease;

      &:hover {
        color: var(--color-primary);
      }

      svg {
        width: 100%;
        height: 100%;
        display: block;
      }
    }

    &__logo {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      color: var(--color-white);
      transition: opacity 0.2s ease;

      &:hover {
        opacity: 0.9;
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 4px;
        border-radius: 4px;
      }
    }

    &__logoIcon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      background-color: var(--color-primary);
      border-radius: 0.5rem;
      font-weight: 700;
      font-size: 1.25rem;
      color: var(--color-white);
      flex-shrink: 0;
    }

    &__logoText {
      font-weight: 700;
      font-size: 1.125rem;
    }

    &__description {
      color: #9ca3af;
      margin: 0;
      max-width: 280px;
    }

    &__colTitle {
      font-size: 1rem;
      font-weight: 600;
      margin: 0;
      color: var(--color-white);
    }

    &__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    &__listItem {
      margin: 0;
    }

    &__link {
      color: #9ca3af;
      text-decoration: none;
      transition: color 0.2s ease;
      display: inline-block;

      &:hover,
      &:focus-visible {
        color: var(--color-primary-hover);
        outline: none;
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        border-radius: 2px;
      }
    }

    &__address {
      font-style: normal;
      margin: 0;
    }

    &__contactList {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    &__contactItem {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: #9ca3af;
      margin: 0;
    }

    &__contactIcon {
      width: 1.125rem;
      height: 1.125rem;
      flex-shrink: 0;
      color: var(--color-primary);
    }

    &__contactLink {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;

      &:hover,
      &:focus-visible {
        color: var(--color-primary-hover);
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        border-radius: 2px;
      }
    }

    &__bottom {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding-top: 1.5rem;
      border-top: 1px solid #1f2937;
    }

    &__copyright {
      margin: 0;
      color: #9ca3af;
      font-size: 0.875rem;
      text-align: center;
    }

    &__legal {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem;
    }

    &__legalLink {
      color: #9ca3af;
      text-decoration: none;
      font-size: 0.875rem;
      transition: color 0.2s ease;

      &:hover,
      &:focus-visible {
        color: var(--color-primary-hover);
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        border-radius: 2px;
      }
    }

    @media (max-width: 1024px) {
      &__grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
      }

      &__col--brand {
        grid-column: 1 / -1;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
      }

      &__description {
        max-width: none;
        order: 3;
        width: 100%;
        margin-top: 0.5rem;
      }

      &__social {
        order: 2;
      }
    }

    @media (max-width: 576px) {
      padding: 2.5rem 0 1rem;

      &__grid {
        grid-template-columns: 1fr;
        gap: 2rem 1rem;
      }

      &__col--brand {
        flex-direction: column;
        align-items: flex-start;
        text-align: left;
      }

      &__logo {
        gap: 0.75rem;
      }

      &__logoIcon {
        width: 2.75rem;
        height: 2.75rem;
        font-size: 1.375rem;
      }

      &__logoText {
        font-size: 1.25rem;
      }

      &__description {
        order: unset;
        margin-top: 0;
      }

      &__social {
        order: unset;
      }

      &__bottom {
        flex-direction: column;
        text-align: center;
        gap: 1.25rem;
      }

      &__legal {
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
      }
    }

    @media (max-width: 360px) {
      &__logoIcon {
        width: 2.5rem;
        height: 2.5rem;
        font-size: 1.25rem;
      }
      &__logoText {
        font-size: 1.125rem;
      }
      &__contactItem {
        font-size: 0.875rem;
      }
    }

    @media print {
      &__social,
      &__legal {
        display: none;
      }
      &__contactLink {
        text-decoration: none !important;
        color: #000 !important;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        transition: none !important;
        animation: none !important;
        transform: none !important;
      }
    }

    @media (prefers-contrast: more) {
      &__link:focus-visible,
      &__contactLink:focus-visible,
      &__legalLink:focus-visible,
      &__logo:focus-visible,
      &__socialLink:focus-visible {
        outline-width: 3px;
        outline-color: var(--color-white);
      }
    }
  }
</style>
