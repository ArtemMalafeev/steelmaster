---
import { Image } from "astro:assets";

import main from "../images/main.jpg";

import img1 from "../images/calculator/1.jpg";
import img2 from "../images/calculator/2.jpg";
import img3 from "../images/calculator/3.jpg";
import img4 from "../images/calculator/4.jpg";
import img5 from "../images/calculator/5.png";
import img6 from "../images/calculator/6.png";
import img7 from "../images/calculator/7.png";
import img8 from "../images/calculator/8.png";
import img9 from "../images/calculator/9.png";
import img10 from "../images/calculator/10.jpeg";
import img11 from "../images/calculator/11.jpg";

import defaultImg from "../images/calculator/default.png";

const steps = [
  {
    id: 1,
    title: "Какой забор хотели бы установить ?",
    gridColumns: 2,
    // description: "Выберите тип конструкции",
    options: [
      {
        id: "option1",
        label: "Забор жалюзи",
        img: img1,
      },
      {
        id: "option2",
        label: "Забор из штакетника",
        img: img2,
      },
      { id: "option3", label: "Забор рабица", img: img3 },
      {
        id: "option4",
        label: "Забор из профнастила",
        img: img4,
      },
    ],
  },
  {
    id: 2,
    title: "Какой цвет забора вам бы хотелось ?",
     gridColumns: 3,
    // description: "Какой тип забора вам нужен?",
    options: [
      {
        id: "option5",
        label: "Черный",
        img: img5,
      },
      {
        id: "option6",
        label: "Коричневый",
        img: img6,
      },
      {
        id: "option7",
        label: "Серый",
        img: img7,
      },
      {
        id: "option8",
        label: "Красный",
        img: img8,
      },
      {
        id: "option9",
        label: "Граффит",
        img: img9,
      },
      {
        id: "option10",
        label: "Другое",
        img: defaultImg,
      },
    ],
  },
  {
    id: 3,
    title: "Выберите ворота ?",
     gridColumns: 3,
    // description: "Из чего будет конструкция?",
    options: [
      {
        id: "option11",
        label: "Распашные ворота",
        img: img10,
      },
      {
        id: "option12",
        label: "Откатные ворота",
        img: img11,
      },
      {
        id: "option13",
        label: "Не нужны ворота",
        img: defaultImg,
      },
    ],
  },
  {
    id: 4,
    title: "Выберите площадь забора ?",
     gridColumns: 3,
    // description: "Выберите примерный метраж",
    options: [
      { id: "option14", label: "до 1500 кв.м" },
      { id: "option15", label: "от 1000 до 1500 кв.м" },
      { id: "option16", label: "от 1500 до 2000 кв.м" },
      { id: "option17", label: "от 2000 до 2500 кв.м" },
      { id: "option18", label: "от 2500 до 3000 кв.м" },
      { id: "option19", label: "свыше 3000 кв.м" },
    ],
  },

];
---

<section
  id="calculator"
  class="section calculator"
  aria-labelledby="calculator-title"
>
  <div class="container">
    <div class="calculator__top">
      <h2 id="calculator-title" class="calculator__title">
        Рассчитайте стоимость забора
      </h2>
      <p class="calculator__subtitle">
        Ответьте на 5 простых вопросов и получите расчет
      </p>
    </div>

    <div class="calculator__container">
      <!-- Форма -->
      <form id="calcForm" class="calculator__form">
        {
          steps.map((step, index) => (
            <div
              class="calculator__step"
              data-step={step.id}
              hidden={index !== 0}
            >
              <h3 class="calculator__titleStep">{step.title}</h3>
              {/* <p class="calculator__desc">{step.description}</p> */}

              {step.options ? (
  <div 
    class={`calculator__options calculator__options--cols-${step.gridColumns || 2}`}
  >
    {step.options.map((opt) => (
 <label class="calculator__option">
  <input
    type="radio"
    name={`step-${step.id}`}
    value={opt.id}
    class="calculator__optionInput"
  />
  <div class={`calculator__optionCard ${!opt.img ? 'calculator__optionCard--text-only' : ''}`}>
    
    {/* Изображение — только если оно есть */}
    {opt.img && (
      <div class="calculator__optionImage">
        <Image src={opt.img} alt={opt.label} loading="lazy" />
      </div>
    )}
    
    <div class="calculator__optionContent">
      <h4 class="calculator__optionLabel">{opt.label}</h4>
      {opt.desc && <p class="calculator__optionDesc">{opt.desc}</p>}
    </div>
  </div>
</label>
    ))}
  </div>
) : step.formFields ? (
                <div class="calculator__formFields">
                  {step.formFields.map((field) => (
                    <div class="calculator__formField">
                      <label class="calculator__formLabel" for={field.id}>
                        {field.label}
                      </label>
                      {field.type === "textarea" ? (
                        <textarea
                          id={field.id}
                          name={field.id}
                          class="calculator__formInput"
                          placeholder={field.placeholder}
                          required={field.required}
                        />
                      ) : (
                        <input
                          id={field.id}
                          name={field.id}
                          type={field.type}
                          class="calculator__formInput"
                          placeholder={field.placeholder}
                          required={field.required}
                        />
                      )}
                    </div>
                  ))}
                </div>
              ) : null}
            </div>
          ))
        }

        <!-- Кнопки -->
        <div class="calculator__nav">
          <button
            type="button"
            id="btnPrev"
            class="calculator__btn calculator__btn--back"
            disabled
          >
            Назад
          </button>
          <button
            type="button"
            id="btnNext"
            class="calculator__btn calculator__btn--next"
          >
            Далее
          </button>
          <button
            type="submit"
            id="btnSubmit"
            class="calculator__btn calculator__btn--submit"
            hidden
          >
            Отправить
          </button>
        </div>
      </form>

      <!-- Успех -->
      <div id="successBlock" class="calculator__success" hidden>
        <div class="calculator__successIcon">✓</div>
        <h3 class="calculator__successTitle">Готово!</h3>
        <p class="calculator__successDesc">
          Заявка отправлена, мы свяжемся с вами в течение 15 минут
        </p>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .calculator {
    padding: 20px 0;
    font-family: var(--font-main);

    position: relative;
    background: linear-gradient(160deg, #f8f9fb 0%, #eef2f7 100%);
    overflow: hidden; // Чтобы декоративные элементы не вылезали за секцию

    &::before,
    &::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.5;
      pointer-events: none;
    }
    &::before {
      width: 450px;
      height: 450px;
      top: -120px;
      left: -100px;
      background: radial-gradient(
        circle,
        rgba(245, 73, 0, 0.18),
        transparent 70%
      );
    }
    &::after {
      width: 500px;
      height: 500px;
      bottom: -150px;
      right: -120px;
      background: radial-gradient(
        circle,
        rgba(54, 65, 83, 0.12),
        transparent 70%
      );
    }

    &__top {
      display: flex;
      flex-direction: column;
      row-gap: 18px;
      text-align: center;
      text-align: center;
    }

    &__subtitle {
      font-size: 22px;
      color: var(--color-secondary);
    }

    &__container {
      max-width: 850px;
      margin: 0 auto;
      margin-top: 24px;
      background: var(--color-white);
      border-radius: 16px;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      max-height: 95vh;
    }

    &__progress {
      padding: 12px 20px;
      flex-shrink: 0;
    }

    &__progressInfo {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
      font-size: 13px;
      font-weight: 700;
      color: var(--color-secondary);
    }

    &__progressTrack {
      width: 100%;
      height: 4px;
      background: rgb(202, 202, 202);
      border-radius: 2px;
      overflow: hidden;
    }

    &__progressFill {
      height: 100%;
      width: 0;
      background: linear-gradient(
        90deg,
        var(--color-primary),
        var(--color-primary-hover)
      );
      border-radius: 2px;
      transition: width 0.25s ease-out;
      will-change: width;
    }

    &__form {
      padding: 16px 20px 20px;
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    &__step[hidden] {
      display: none;
    }

    &__titleStep {
      font-size: 18px;
      font-weight: 700;
      color: var(--color-secondary);
      margin: 0 0 4px;
      line-height: 1.2;
    }

    &__desc {
      font-size: 13px;
      color: var(--color-gray-700);
      margin: 0 0 16px;
      line-height: 1.3;
    }

 &__options {
  margin-top: 14px;
  display: grid;
  gap: 10px;
  margin-bottom: 16px;
  
  // По умолчанию — 2 колонки
  grid-template-columns: repeat(2, 1fr);
  
  // Модификаторы для количества колонок
  &--cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }
  &--cols-3 {
    grid-template-columns: repeat(3, 1fr);
  }
}

// Адаптив: на мобильных всегда 1 колонка
@media (max-width: 576px) {
  &__options {
    grid-template-columns: 1fr !important;
    gap: 8px;
  }
}

    &__optionInput {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    &__optionCard {
      display: flex;
      flex-direction: column;
      padding: 8px;
      border: 2px solid rgb(226, 226, 226);
      border-radius: 12px;
      background: var(--color-white);
      cursor: pointer;
      transition: all 0.15s ease;
      height: 100%;
      box-sizing: border-box;
      text-align: center;
      box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
    }

    &__optionInput:checked + &__optionCard {
      border-color: var(--color-primary);
      background: rgba(245, 73, 0, 0.04);
    }

    &__optionImage {
      width: 100%;
      height: 200px;
      flex-shrink: 0;
      border-radius: 8px;
      background: var(--color-bg-3);
      margin-bottom: 8px;
      overflow: hidden; /* ⭐ Обрезаем всё, что вылезает */
      display: flex; /* ⭐ Центрируем картинку */
      align-items: center;
      justify-content: center;

       &--text-only {
    justify-content: center;
    padding: 16px 12px;
    min-height: 80px;
    
    .calculator__optionContent {
      text-align: center;
    }
    
    .calculator__optionLabel {
      font-size: 14px;
      white-space: normal;
      line-height: 1.3;
    }
  }

      /* ⭐ Стили для Astro Image */
      :global(img) {
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
        display: block;
        border-radius: 8px;
      }
    }

    &__optionContent {
      display: flex;
      flex-direction: column;
      text-align: left;
      min-width: 0;
    }

    &__optionLabel {
      font-size: 14px;
      font-weight: 600;
      color: var(--color-secondary);
      margin: 0 0 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      width: 100%;
    }

    &__formFields {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 16px;
    }

    &__formField {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    // Если есть изображение — высота фиксированная
&__optionImage {
  width: 100%;
  height: 140px; // ← уменьшил для компактности
  flex-shrink: 0;
  border-radius: 8px;
  background: var(--color-bg-3);
  margin-bottom: 8px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;

  :global(img) {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block;
    border-radius: 8px;
  }
}

// Адаптив: на мобильных карточки с картинками — горизонтальные
@media (max-width: 576px) {
  &__optionCard:not(&__optionCard--text-only) {
    flex-direction: row;
    align-items: center;
    text-align: left;
    
    .calculator__optionImage {
      width: 60px;
      height: 60px;
      margin-bottom: 0;
      margin-right: 12px;
    }
    
    .calculator__optionContent {
      text-align: left;
      flex: 1;
    }
  }
  
  // Текст-карточки остаются как есть, но с отступами
  &__optionCard--text-only {
    padding: 12px;
  }
}

    &__formLabel {
      font-size: 13px;
      font-weight: 500;
      color: var(--color-secondary);
    }

    &__formInput {
      padding: 10px 12px;
      font-size: 14px;
      border: 2px solid var(--color-bg-2);
      border-radius: 8px;
      background: var(--color-white);
      color: var(--color-secondary);
      transition: border-color 0.15s;
    }

    &__formInput:focus {
      outline: none;
      border-color: var(--color-primary);
    }

    &__nav {
      display: flex;
      justify-content: space-between;
      padding-top: 12px;
      border-top: 1px solid var(--color-bg-2);
      margin-top: auto;
      flex-shrink: 0;
    }

    &__btn {
      padding: 10px 20px;
      font-size: 14px;
      font-weight: 600;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.15s ease;
    }

    &__btn--back {
      background: transparent;
      color: var(--color-secondary);
      &:hover:not(:disabled) {
        background: var(--color-btn-outline-hover);
      }
      &:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
    }

    &__btn--next,
    &__btn--submit {
      background: var(--color-primary);
      color: var(--color-white);
      &:hover {
        background: var(--color-primary-hover);
      }
    }

    &__btn--submit {
      background: var(--color-secondary);
      &:hover {
        background: var(--color-secondary-hover);
      }
    }

    &__success {
      padding: 32px 20px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex: 1;
      &[hidden] {
        display: none;
      }
    }

    &__successIcon {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--color-primary);
      color: var(--color-white);
      font-size: 24px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 12px;
    }

    &__successTitle {
      font-size: 18px;
      font-weight: 700;
      color: var(--color-secondary);
      margin: 0 0 6px;
    }

    &__successDesc {
      font-size: 14px;
      color: var(--color-gray-700);
      margin: 0;
      max-width: 280px;
    }
  }

  @keyframes shake {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-4px);
    }
    75% {
      transform: translateX(4px);
    }
  }

  .shake {
    animation: shake 0.2s ease;
  }

  @media (max-width: 576px) {
    .calculator {
      &__container {
        border-radius: 12px;
        margin: 0 8px;
        margin-top: 20px;
      }
      &__progress {
        padding: 10px 16px;
      }
      &__form {
        padding: 12px 16px 16px;
      }
      &__options {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      &__optionCard {
        flex-direction: row;
        align-items: center;
        padding: 8px;
        text-align: left;
      }

      &__optionContent {
        align-items: flex-start;
      }

      &__title {
        font-size: 17px;
      }
      &__desc {
        font-size: 13px;
        margin-bottom: 12px;
      }
      &__nav {
        flex-direction: column-reverse;
        gap: 8px;
        padding-top: 10px;
      }
      &__btn {
        width: 100%;
        padding: 12px;
      }
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const steps = document.querySelectorAll(".calculator__step");
    const totalSteps = steps.length;

    // Прогресс-бар — опционально, с проверкой на существование
    const progressFill = document.getElementById("progressFill");
    const stepCurrent = document.getElementById("stepCurrent");
    const stepPercent = document.getElementById("stepPercent");

    const btnPrev = document.getElementById("btnPrev");
    const btnNext = document.getElementById("btnNext");
    const btnSubmit = document.getElementById("btnSubmit");
    const form = document.getElementById("calcForm");
    const successBlock = document.getElementById("successBlock");

    let currentStep = 1;

    function updateProgress() {
      // Обновляем прогресс только если элементы есть в DOM
      if (progressFill && stepCurrent && stepPercent) {
        const percent = Math.round((currentStep / totalSteps) * 100);
        progressFill.style.width = `${percent}%`;
        stepCurrent.textContent = currentStep;
        stepPercent.textContent = `${percent}%`;
      }

      // Кнопка "Назад"
      if (btnPrev) {
        btnPrev.disabled = currentStep === 1;
      }

      // Переключение кнопок Далее/Отправить
      if (btnNext && btnSubmit) {
        if (currentStep === totalSteps) {
          btnNext.hidden = true;
          btnSubmit.hidden = false;
        } else {
          btnNext.hidden = false;
          btnSubmit.hidden = true;
        }
      }
    }

    function showStep(stepNum) {
      steps.forEach((step, index) => {
        step.hidden = index !== stepNum - 1;
      });
      currentStep = stepNum;
      updateProgress();
      
      // Скролл к началу формы при смене шага (удобно на мобильных)
      const formContainer = document.querySelector(".calculator__form");
      if (formContainer) {
        formContainer.scrollTo({ top: 0, behavior: "smooth" });
      }
    }

    function validateCurrentStep() {
      const activeStep = document.querySelector(
        ".calculator__step:not([hidden])",
      );
      if (!activeStep) return false;

      // Валидация радио-кнопок
      const radios = activeStep.querySelectorAll('input[type="radio"]');
      if (radios.length > 0) {
        const checked = activeStep.querySelector('input[type="radio"]:checked');
        if (!checked) {
          // Анимация "тряски" для карточек
          activeStep
            .querySelectorAll(".calculator__optionCard")
            .forEach((card) => {
              card.classList.remove("shake");
              void card.offsetWidth; // reflow для перезапуска анимации
              card.classList.add("shake");
            });
          return false;
        }
      }

      // Валидация обязательных полей
      const required = activeStep.querySelectorAll("[required]");
      for (const field of required) {
        if (!field.value.trim()) {
          field.style.borderColor = "var(--color-primary)";
          setTimeout(() => (field.style.borderColor = ""), 1500);
          return false;
        }
      }

      return true;
    }

    // Кнопка "Далее"
    btnNext?.addEventListener("click", () => {
      if (validateCurrentStep() && currentStep < totalSteps) {
        showStep(currentStep + 1);
      }
    });

    // Кнопка "Назад" — теперь работает ✅
    btnPrev?.addEventListener("click", () => {
      if (currentStep > 1) {
        showStep(currentStep - 1);
      }
    });

    // Отправка формы
    form?.addEventListener("submit", (e) => {
      e.preventDefault();

      const data = {};
      
      // Собираем текстовые поля
      form.querySelectorAll("input, textarea").forEach((el) => {
        if (el.name && el.value) data[el.name] = el.value;
      });
      
      // Собираем выбранные радио-кнопки
      form.querySelectorAll('input[type="radio"]:checked').forEach((el) => {
        data[`step_${el.name.split('-')[1]}`] = el.value;
      });

      console.log("Заявка:", data);

      // Показываем блок успеха
      if (form && successBlock) {
        form.hidden = true;
        successBlock.hidden = false;
      }
      
      // Здесь можно добавить реальную отправку на сервер:
      // await fetch('/api/submit', { method: 'POST', body: JSON.stringify(data) })
    });

    // Инициализация
    requestAnimationFrame(() => {
      updateProgress();
    });
  });
</script>
