  }
];
---

<section id="choose" class="section choose" aria-labelledby="choose-title">
  <div class="container">
    <div class="choose__container">
      <div class="choose__top">
        <h2 id="choose-title" class="choose__title">Почему выбирают нас</h2>
        <p class="choose__subtitle">
          Более 500 довольных клиентов доверили нам свои участки
        </p>
      </div>
      <ul class="choose__list">
        {
          advantages.map((item) => (
            <li class="choose__item">
              <div class="choose__icon" aria-hidden="true" set:html={item.icon} />
              <div class="choose__icon" aria-hidden="true" set:html={item.icon} />
              <h3 class="choose__itemTitle">{item.title}</h3>
              <p class="choose__description">{item.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
  .choose {
    background: var(--color-white);
    text-align: center;

    &__top {
      display: flex;
      flex-direction: column;
      row-gap: 18px;
    }

    &__subtitle {
      font-size: 22px;
      color: var(--color-secondary);
    }

    &__icon {
      display: flex;
      align-items: center;
      justify-content: center;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      padding: 10px;
      color: var(--color-primary);
      background: var(--color-bg-3);
      background: var(--color-bg-3);
      border-radius: 12px;
    }

    &__itemTitle {
      margin-top: 10px;
      font-size: 20px;
      font-weight: 500;
    }

    &__description {
      font-size: 16px;
      line-height: 1.4;
      color: var(--color-secondary);
    }

    &__list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-top: 50px;

      @media screen and (min-width: 720px) {
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      }
    }

    &__item {
      display: flex;
      flex-direction: column;
      row-gap: 4px;
      row-gap: 4px;
      padding: 20px;
      border-radius: 16px;
      text-align: left;
      background: var(--color-bg-2);
      background: var(--color-bg-2);

      transition: box-shadow 0.25s ease;

      &:hover {
        box-shadow: 0 12px 24px -6px rgba(0, 0, 0, 0.12);
      }
    }
  }
</style>
