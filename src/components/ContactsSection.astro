---
import PhoneIcon from "../components/icons/Phone.astro";
import MapIcon from "../components/icons/Map.astro";
import WatchIcon from "../components/icons/Watch.astro";
import EmailIcon from "../components/icons/Email.astro";
---

<section
  id="contacts"
  class="contacts section"
  aria-labelledby="contacts-title"
>
  <div class="container">
    <div class="contacts__container">
      <div class="contacts__top">
        <h2 class="contacts__title" id="contacts-title">Контакты</h2>
        <p class="contacts__subtitle">Свяжитесь с нами удобным способом</p>
      </div>

      <div class="contacts__grid">
        <div class="contacts__info">
          <div class="contact-card">
            <div class="contact-card__icon" aria-hidden="true">
              <div class="contact-card__svg"><PhoneIcon  /></div>
            </div>
            <div class="contact-card__content">
              <h3 class="contact-card__title">Телефон</h3>
              <a
                href="tel:+79991234567"
                class="contact-card__link contact-card__link--phone"
                >+7 (918) 768 30 88</a
              >
            </div>
          </div>

            <div class="contact-card">
            <div class="contact-card__icon" aria-hidden="true">
              <div class="contact-card__svg"><EmailIcon  /></div>
            </div>
            <div class="contact-card__content">
              <h3 class="contact-card__title">Почта</h3>
              <a
                href="mailto:valeriya.k1995@icloud.com"
                class="contact-card__link contact-card__link--phone"
                >valeriya.k1995@icloud.com</a
              >
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-card__icon" aria-hidden="true">
               <div class="contact-card__svg"><MapIcon  /></div>
            </div>
            <div class="contact-card__content">
              <h3 class="contact-card__title">Адрес офиса</h3>
              <p class="contact-card__text">Шпаковский р-н, х. Вязники, 92</p>
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-card__icon" aria-hidden="true">
               <div class="contact-card__svg"><WatchIcon /></div>
            </div>
            <div class="contact-card__content">
              <h3 class="contact-card__title">Режим работы</h3>
              <p class="contact-card__text">Пн-Пт: 9:00-18:00</p>
            </div>
          </div>

          <div class="contacts__promo">
            <h4 class="contacts__promoTitle">🎁 Бесплатный замер!</h4>
            <p class="contacts__promoText">
              Наш специалист приедет в удобное для вас время, произведет точные
              замеры и рассчитает итоговую стоимость.
            </p>
            <p class="contacts__promoNote">
              Выезд мастера по Ставрополю и Михайловску — бесплатно
            </p>
          </div>
        </div>

        <div class="contacts__map">
          <div class="contacts__mapWrapper">
            <div class="yandex-map__container">
              <div
                class="yandex-map__widget"
                style="position:relative;overflow:hidden;"
              >
                <a
                  href="https://yandex.ru/maps/org/masterstal/183730944868/?utm_medium=mapframe&utm_source=maps"
                  style="color:#eee;font-size:12px;position:absolute;top:0px;"
                  >МастерСталь</a
                >
                <a
                  href="https://yandex.ru/maps/11069/stavropol-krai/category/wrought_iron/184107695/?utm_medium=mapframe&utm_source=maps"
                  style="color:#eee;font-size:12px;position:absolute;top:14px;"
                  >Кованые изделия в Ставропольском крае</a
                >
                <a
                  href="https://yandex.ru/maps/11069/stavropol-krai/category/automatic_doors_and_gates/184107661/?utm_medium=mapframe&utm_source=maps"
                  style="color:#eee;font-size:12px;position:absolute;top:28px;"
                  >Автоматические двери и ворота в Ставропольском крае</a
                >

                <iframe
                  src="https://yandex.ru/map-widget/v1/org/masterstal/183730944868/?ll=41.976342%2C45.107483&z=16"
                  width="560"
                  height="400"
                  allowfullscreen="true"
                  style="position:relative;"></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .contacts {
    --contacts-bg: var(--color-bg-2);
    --contacts-text: var(--color-secondary);
    --contacts-text-muted: var(--color-gray-700);
    --contacts-primary: var(--color-primary);
    --contacts-primary-hover: var(--color-primary-hover);
    --contacts-white: var(--color-white);
    --contacts-bg-accent: var(--color-bg-3);
    --contacts-border-radius: 16px;
    --contacts-transition: 0.2s ease;

    background-color: var(--contacts-bg);
    padding: 4rem 0;

    &__top {
      position: relative;
      display: flex;
      flex-direction: column;
      row-gap: 18px;
      text-align: center;
    }

    &__subtitle {
      font-size: 22px;
      color: var(--color-secondary);
    }
  }

  .contacts__grid {
    margin-top: 30px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 3rem;
    align-items: start;
  }

  .contacts__info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 0;

    &__svg {
      width: 24px;
      height: 24px;
    }

    &__icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 3rem;
      height: 3rem;
      background-color: var(--contacts-bg-accent);
      border-radius: 0.75rem;
      color: var(--contacts-primary);
      flex-shrink: 0;
      transition: transform var(--contacts-transition);

      svg {
        width: 1.5rem;
        height: 1.5rem;
      }

      .contact-card:hover & {
        transform: scale(1.05);
      }
    }

    &__content {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      flex: 1;
    }

    &__link {
      font-size: 1.25rem;
      font-weight: 500;
      color: var(--contacts-primary);
      text-decoration: none;
      transition: color var(--contacts-transition);
      line-height: 1.2;

      &:hover,
      &:focus-visible {
        color: var(--contacts-primary-hover);
        outline: none;
      }

      &:focus-visible {
        outline: 2px solid var(--contacts-primary);
        outline-offset: 2px;
        border-radius: 4px;
      }

      &--phone {
        font-size: 1.375rem;
      }
    }

    &__text {
      font-size: 1rem;
      color: var(--contacts-text);
      margin: 0;
      line-height: 1.4;
    }

    &__note {
      font-size: 0.875rem;
      color: var(--contacts-text-muted);
      margin: 0;
      line-height: 1.4;
    }
  }

  .contacts__promo {
    margin-top: 0.5rem;
    padding: 1.5rem;
    background-color: var(--contacts-bg-accent);
    border-left: 4px solid var(--contacts-primary);
    border-radius: 0 var(--contacts-border-radius) var(--contacts-border-radius)
      0;

    &Title {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--contacts-text);
      margin: 0 0 0.75rem;
      line-height: 1.3;
    }

    &Text {
      font-size: 1rem;
      color: var(--contacts-text);
      margin: 0 0 0.5rem;
      line-height: 1.5;
    }

    &Note {
      font-size: 0.875rem;
      color: var(--contacts-text-muted);
      margin: 0;
      font-weight: 500;
    }
  }

  .contacts__map {
    height: 100%;
    min-height: 500px;
  }

  .contacts__mapWrapper {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 500px;
    border-radius: var(--contacts-border-radius);
    overflow: hidden;
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
    background-color: var(--contacts-white);
  }

  .contacts__mapFrame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;

    @media (prefers-reduced-motion: no-preference) {
      transition: opacity 0.3s ease;
      opacity: 0;

      &:loaded {
        opacity: 1;
      }
    }
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contacts__mapWrapper {
    position: relative;
    width: 100%;
    min-height: 500px;
    border-radius: var(--contacts-border-radius);
    overflow: hidden;
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
    background-color: var(--contacts-white);
  }

  .yandex-map__container {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
  }

  .yandex-map__widget {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .yandex-map__widget iframe {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    border: none !important;
  }

  @media (max-width: 1024px) {
    .contacts__mapWrapper {
      min-height: 400px;
    }
  }

  @media (max-width: 576px) {
    .contacts__mapWrapper {
      min-height: 300px;
      border-radius: var(--contacts-border-radius);
    }
  }

  @media (max-width: 1024px) {
    .contacts__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .contacts__map {
      min-height: 400px;
      order: -1;
    }

    .contacts__mapWrapper {
      min-height: 400px;
      border-radius: var(--contacts-border-radius);
    }
  }

  @media (max-width: 576px) {
    .contacts {
      padding: 3rem 0;
    }

    .contact-card {
      gap: 0.875rem;
      padding: 0.75rem 0;

      &__icon {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 0.625rem;
      }

      &__link {
        font-size: 1.125rem;

        &--phone {
          font-size: 1.25rem;
        }
      }

      &__title {
        font-size: 0.9375rem;
      }

      &__text,
      &__note {
        font-size: 0.875rem;
      }
    }

    .contacts__promo {
      padding: 1.25rem;
      border-radius: var(--contacts-border-radius);
      border-left-width: 0;
      border-top: 4px solid var(--contacts-primary);

      &Title {
        font-size: 1rem;
      }
      &Text {
        font-size: 0.9375rem;
      }
      &Note {
        font-size: 0.8125rem;
      }
    }

    .contacts__map {
      min-height: 300px;
      order: unset;
    }

    .contacts__mapWrapper {
      min-height: 300px;
      border-radius: var(--contacts-border-radius);
    }
  }

  @media (max-width: 360px) {
    .contact-card__link--phone {
      font-size: 1.125rem;
      word-break: break-all;
    }
    .contacts__promo {
      padding: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
      animation: none !important;
      transform: none !important;
    }
  }

  @media (prefers-contrast: more) {
    .contact-card__link:focus-visible,
    .contacts__promo {
      outline-width: 3px;
    }
  }

  @media print {
    .contacts__map {
      display: none;
    }
    .contact-card__link {
      text-decoration: none !important;
      color: #000 !important;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const mapFrame = document.querySelector(".contacts__mapFrame");
    if (mapFrame) {
      mapFrame.addEventListener("load", () => {
        mapFrame.classList.add("loaded");
        mapFrame.style.opacity = "1";
      });

      if (mapFrame.complete) {
        mapFrame.classList.add("loaded");
        mapFrame.style.opacity = "1";
      }
    }
  });
</script>
