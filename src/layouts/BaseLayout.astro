  <body>
    <slot />

    <div class="privacy-bar" id="privacyBar" role="alert" aria-live="polite">
      <div class="privacy-bar__container">
        <div class="privacy-bar__icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <p class="privacy-bar__text">
          Мы используем ваши данные только для связи с вами.
          <a href="/policy.pdf" target="_blank" class="privacy-bar__link">
            Политика конфиденциальности
          </a>
        </p>
        <button
          class="privacy-bar__btn"
          id="privacyAcceptBtn"
          type="button"
          aria-label="Принять и закрыть"
        >
          OK
        </button>
      </div>
    </div>
  </body>
</html>

<style lang="scss">
  .privacy-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: white;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.08);
    transition:
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);

    &.hidden {
      transform: translateY(100%);
      opacity: 0;
      pointer-events: none;
    }

    &__container {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      max-width: 1200px;
      margin: 0 auto;
    }

    &__icon {
      flex-shrink: 0;
      color: var(--color-primary);
      display: none;

      @media (min-width: 640px) {
        display: block;
      }
    }

    &__text {
      flex: 1;
      margin: 0;
      font-size: 12px;
      line-height: 1.5;
      color: var(--color-secondary, #333);

      @media (min-width: 640px) {
        font-size: 13px;
      }
    }

    &__link {
      color: var(--color-primary);
      text-decoration: none;
      font-weight: 500;
      white-space: nowrap;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s ease;

      &:hover {
        border-bottom-color: currentColor;
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        border-radius: 2px;
      }
    }

    &__btn {
      flex-shrink: 0;
      padding: 8px 20px;
      background: var(--color-primary);
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;

      &:hover {
        background: var(--color-primary-hover);
        transform: scale(1.05);
      }

      &:active {
        transform: scale(0.97);
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
      }
    }
  }

  @media (max-width: 639px) {
    .privacy-bar {
      &__container {
        flex-wrap: wrap;
        gap: 8px;
        padding: 10px 12px;
      }

      &__text {
        font-size: 11px;
        flex: 1 1 100%;
        order: -1;
      }

      &__btn {
        margin-left: auto;
        padding: 6px 16px;
        font-size: 12px;
        border-radius: 8px;
      }
    }

    body {
      padding-bottom: 50px;
      transition: padding-bottom 0.4s ease;
    }
  }

  @media (min-width: 640px) {
    .privacy-bar {
      bottom: 20px;
      left: 20px;
      right: auto;
      max-width: 420px;
      border-radius: 14px;
      border: 1px solid rgba(0, 0, 0, 0.06);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);

      &__container {
        padding: 14px 18px;
      }
    }
  }
</style>

<script>
  (function () {
    const STORAGE_KEY = "privacy_accepted";
    const bar = document.getElementById("privacyBar");
    const acceptBtn = document.getElementById("privacyAcceptBtn");

    if (localStorage.getItem(STORAGE_KEY) === "true") {
      if (bar) {
        bar.classList.add("hidden");
        document.body.style.paddingBottom = "0";
      }
      return;
    }

    if (bar) {
      setTimeout(() => {
        bar.style.transform = "translateY(0)";
      }, 500);
    }

    if (acceptBtn && bar) {
      acceptBtn.addEventListener("click", () => {
        bar.classList.add("hidden");
        localStorage.setItem(STORAGE_KEY, "true");

        setTimeout(() => {
          document.body.style.paddingBottom = "0";
        }, 400);
      });
    }
  })();
</script>
