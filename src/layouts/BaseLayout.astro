<style lang="scss">
  .privacy-agreement {
    position: fixed;
    bottom: 0;
    right: 0;
    left: 0;
    z-index: 999;
    padding: 12px 20px;
    background: var(--color-white);
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.06);
    font-size: 13px;
    color: var(--color-secondary);
    line-height: 1.4;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;

    &.hidden {
      transform: translateY(100%);
      opacity: 0;
      pointer-events: none;
    }

    @media (min-width: 768px) {
      position: fixed;
      bottom: 16px;
      right: 24px;
      left: auto;
      width: auto;
      max-width: 380px;
      padding: 12px 18px 12px 20px;
      border-radius: 12px;
      border: 1px solid rgba(0, 0, 0, 0.08);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    }

    &__content {
      margin: 0 auto;
      max-width: 1200px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;

      @media (min-width: 768px) {
        justify-content: flex-start;
      }
    }

    &__text {
      display: block;
      text-align: center;
      flex: 1;

      @media (min-width: 768px) {
        text-align: left;
        padding-right: 8px;
      }
    }

    &__link {
      color: var(--color-primary);
      text-decoration: none;
      font-weight: 500;
      border-bottom: 1px dashed transparent;
      transition: all 0.2s ease;

      &:hover {
        color: var(--color-primary-hover);
        border-bottom-color: var(--color-primary);
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        border-radius: 4px;
      }
    }

    &__close {
      flex-shrink: 0;
      width: 32px;
      height: 32px;
      border: none;
      border-radius: 8px;
      background: transparent;
      color: var(--color-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s ease;
      padding: 0;

      &:hover {
        background: var(--color-btn-outline-hover);
        color: var(--color-primary);
        transform: rotate(90deg);
      }

      &:active {
        transform: scale(0.95);
      }

      &:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
      }

      svg {
        display: block;
      }
    }
  }

  @media (max-width: 767px) {
    body {
      padding-bottom: 60px;
    }

    .privacy-agreement {
      max-width: 280px;
      margin-left: auto;
      margin-right: 20px;
      margin-bottom: 10px;
    }
  }
</style>

<script>
  (function () {
    const STORAGE_KEY = "privacy_agreement_dismissed";
    const agreement = document.getElementById("privacyAgreement");
    const closeBtn = document.getElementById("privacyCloseBtn");

    if (localStorage.getItem(STORAGE_KEY) === "true" && agreement) {
      agreement.classList.add("hidden");
      if (window.innerWidth < 768) {
        document.body.style.paddingBottom = "0";
      }
    }

    if (closeBtn && agreement) {
      closeBtn.addEventListener("click", () => {
        agreement.classList.add("hidden");
        localStorage.setItem(STORAGE_KEY, "true");

        if (window.innerWidth < 768) {
          document.body.style.paddingBottom = "0";
        }
      });
    }
  })();
</script>
